{
    "name": "andydefer/laravel-search",
    "version": "1.0.0",
    "description": "Fuzzy search package for Laravel",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AndyDefer\\LaravelSearch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AndyDefer\\LaravelSearch\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Andy Kani",
            "email": "andykanidimbu@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0|^13.0|^14.0|^15.0",
        "andydefer/php-vo": "^0.8.1",
        "andydefer/laravel-repository": "^2.8.2",
        "andydefer/laravel-task": "^3.7.1",
        "andydefer/laravel-directive": "^3.25.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "composer/composer": "^2.0",
        "larastan/larastan": "^3.8",
        "laravel/pint": "^1.26",
        "orchestra/testbench": "^10.8",
        "phpunit/phpunit": "^12.5",
        "rector/rector": "*",
        "symfony/var-dumper": "^7.0",
        "vimeo/psalm": "^6.14"
    },
    "extra": {
        "laravel": {
            "providers": [
                "AndyDefer\\LaravelSearch\\LaravelSearchServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-unit": "phpunit --testsuite=unit",
        "test-integration": "phpunit --testsuite=integration"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
